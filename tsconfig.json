{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"] 
    },
    "types": ["node", "react", "react-dom"], 
    "baseUrl": ".", 
    "outDir": "./dist", 
    "sourceMap": false 
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "*.config.ts", 
    "*.config.js" 
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next/cache", 
    "dist", 
    "**/*.test.ts" 
  ]
}